generator client {
  provider      = "prisma-client"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
  output        = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  DISABLED
  ERROR
}

enum AnomalyType {
  ASSAULT
  FIGHTING
  ROBBERY
  SHOOTING
}

enum PreferenceType {
  SYSTEM_DEFAULT
  USER_PREFERENCE
}

enum ReportType {
  EMAIL
  WHATSAPP
  TELEGRAM
}

enum CameraSourceType {
  LOCAL
  STATIC_FILE
  RTSP_LINK
}

model Users {
  id                  String              @id @default(uuid(7))
  email               String              @unique
  name                String
  password            String
  wa_number           String?
  telegram_username   String?
  profile_picture     String?

  role                Role                @default(USER)

  created_at          DateTime            @default(now())
  updated_at          DateTime            @default(now()) @updatedAt

  refresh_tokens      RefreshTokens[]
  layout_pages        CctvLayoutPages[]
  wa_receiver         WaReceivers[]
  email_receiver      EmailReceivers[]
}

model RefreshTokens {
  id              String    @id @default(uuid(7))
  refresh_token   String    @unique
  user_id         String

  user            Users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  expired_at      DateTime
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt
}

model SystemSettings {
  id                      String    @id @default(uuid(7))
  video_retention_days    Int       @default(7)
  report_auto_send_wa     Boolean   @default(false)
  report_auto_send_email  Boolean   @default(false)
}

model EdgeDevices {
  id                    String          @id @default(uuid(7))
  name                  String
  slug                  String          @unique
  type                  String
  location              String
  max_cameras           Int             @default(1)
  is_inference_active   Boolean         @default(true)
  status                DeviceStatus    @default(OFFLINE)
  error_message         Json?

  created_at            DateTime        @default(now())
  updated_at            DateTime        @default(now()) @updatedAt

  cameras       Cameras[]
}

model Cameras {
  id                  String                @id @default(uuid(7))
  name                String
  slug                String                @unique
  source              String
  source_type         CameraSourceType
  rtsp_username       String?
  rtsp_password       String?
  rtsp_iv             String?
  rtsp_authtag        String?
  status              DeviceStatus          @default(OFFLINE)
  cv_treshold         Float                 @default(0.8)
  error_message       Json?

  edge_device_id      String?
  edge_device         EdgeDevices?          @relation(fields: [edge_device_id], references: [id], onDelete: Cascade)

  created_at          DateTime              @default(now())
  updated_at          DateTime              @default(now()) @updatedAt

  cctv_layout_details CctvLayoutDetails[]
  detected_anomalies  DetectedAnomalies[]
}

model CctvLayoutDetails {
  id              String              @id @default(uuid(7))
  layout_page_id  String              @unique
  layout_json     Json

  layout_pages  CctvLayoutPages       @relation(fields: [layout_page_id], references: [id], onDelete: Cascade)

  created_at      DateTime            @default(now())
  updated_at      DateTime            @default(now()) @updatedAt

  cameras       Cameras[]   // I don't think this would be needed
}

model CctvLayoutPages {
  id                String              @id @default(uuid(7))
  user_id           String?
  preference        PreferenceType      @default(SYSTEM_DEFAULT)
  page              Int

  user              Users?              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at        DateTime            @default(now())
  updated_at        DateTime            @default(now()) @updatedAt

  layout_detail     CctvLayoutDetails?
}

model DetectedAnomalies {
  id                String          @id @default(uuid(7))
  camera_id         String?
  video_path        String?
  video_duration    Int?
  video_start_date  DateTime?
  video_end_date    DateTime?
  anomaly_type      AnomalyType
  confidence        Float
  is_valid          Boolean?
  is_reported       Boolean         @default(false)
  report_sent       Json

  camera            Cameras?        @relation(fields: [camera_id], references: [id], onDelete: SetNull)

  created_at        DateTime        @default(now())
  updated_at        DateTime        @default(now()) @updatedAt
}

model ReportPlatforms {
  id                String          @id @default(uuid(7))
  report_type       ReportType
  platform_name     String
  platform_slug     String          @unique
  status            DeviceStatus    @default(ONLINE)

  created_at        DateTime        @default(now())
  updated_at        DateTime        @default(now()) @updatedAt
}

model WaReceivers {
  id                String          @id @default(uuid(7))
  name              String
  wa_chat_id        String
  is_group          Boolean         @default(false)
  user_id           String?
  is_activated      Boolean         @default(true)

  user              Users?          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at        DateTime        @default(now())
  updated_at        DateTime        @default(now()) @updatedAt
}

model EmailReceivers {
  id                      String              @id @default(uuid(7))
  name                    String
  email                   String
  user_id                 String?
  is_activated            Boolean             @default(true)

  user                    Users?              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at              DateTime            @default(now())
  updated_at              DateTime            @default(now()) @updatedAt
}